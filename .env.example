# Altaviz Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# -----------------------------------------------
# DATABASE (PostgreSQL via Supabase)
# -----------------------------------------------
# Get your connection string from Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# DATABASE_SSL=false                # Set to 'false' to disable SSL (local dev only)
# DB_POOL_MAX=10                    # Max pool connections (default: 10)
# DB_IDLE_TIMEOUT=30000             # Idle timeout in ms (default: 30000)

# -----------------------------------------------
# AUTHENTICATION (NextAuth.js v5)
# -----------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------
# STRIPE BILLING
# -----------------------------------------------
# Free until transactions (2.9% + $0.30 per charge)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_ENTERPRISE=price_...

# -----------------------------------------------
# AGENTIC WORKFLOWS
# -----------------------------------------------
# API key for cron/scheduler auth (generate: openssl rand -hex 32)
# WORKFLOW_API_KEY=
# WORKFLOW_API_KEY_OLD=           # Grace period key during rotation

# -----------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------
# Free tier: 100 emails/day — https://resend.com
# RESEND_API_KEY=re_...

# -----------------------------------------------
# AI AGENTS (Investigation, Work Order, Optimization)
# -----------------------------------------------
# OPENAI_API_KEY=sk-...                  # Required for RAG embeddings (text-embedding-3-small)
# DIAGNOSTICS_MODEL=openai:gpt-4o-mini  # LLM model for all 4 agents
# AGENT_API_URL=http://localhost:8001    # Agent FastAPI sidecar URL

# -----------------------------------------------
# LLM OBSERVABILITY (Langfuse)
# -----------------------------------------------
# Free tier: 50K observations/month — https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com  # Or self-hosted URL

# -----------------------------------------------
# ETL PIPELINE
# -----------------------------------------------
# ETL_ORGANIZATION_ID=  # Default org UUID for pipeline writes

# -----------------------------------------------
# LOGGING
# -----------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------
# AZURE OPENAI (replaces direct OpenAI for agents)
# -----------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# -----------------------------------------------
# AZURE AI SEARCH (hybrid RAG backend)
# -----------------------------------------------
# AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
# AZURE_SEARCH_API_KEY=
# AZURE_SEARCH_INDEX=altaviz-knowledge-base
# SEARCH_BACKEND=pgvector  # or "azure" for Azure AI Search

# -----------------------------------------------
# AZURE ML (model registry + MLOps)
# -----------------------------------------------
# AZURE_ML_WORKSPACE_NAME=altaviz-ml
# AZURE_ML_RESOURCE_GROUP=altaviz-dev-rg
# AZURE_ML_SUBSCRIPTION_ID=
